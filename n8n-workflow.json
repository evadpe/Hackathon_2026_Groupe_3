      "id": "get-gold",
      "name": "Recuperer Zone Gold",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [460, 600]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://backend:8000/documents/pending",
        "options": {}
      },
      "id": "get-pending-report",
      "name": "Recuperer docs en attente rapport",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [460, 740]
    },
    {
      "parameters": {
        "jsCode": "// Construit le rapport journalier\nconst goldDocs = $('Recuperer Zone Gold').all().map(i => i.json);\nconst pendingDocs = $('Recuperer docs en attente rapport').all().map(i => i.json);\n\nconst totalGold = goldDocs.length;\nconst totalPending = pendingDocs.length;\nconst volumeTotal = goldDocs.reduce((sum, d) => sum + (d.extractedData?.total_ttc || 0), 0);\n\nconst lignesGold = goldDocs.map(d =>\n  `- ${d.filename} - ${d.extractedData?.fournisseur || 'N/A'} - ${(d.extractedData?.total_ttc || 0).toFixed(2)} EUR`\n).join('\\n') || \"Aucun document valide aujourd'hui\";\n\nconst rapport = [\n  `Rapport Conformite - ${new Date().toLocaleDateString('fr-FR')}`,\n  `Documents valides (Zone Gold) : ${totalGold}`,\n  `Documents en attente : ${totalPending}`,\n  `Volume total TTC valide : ${volumeTotal.toFixed(2)} EUR`,\n  ``,\n  `Derniers documents valides :`,\n  lignesGold\n].join('\\n');\n\nconsole.log(rapport);\nreturn { json: { rapport, totalGold, totalPending, volumeTotal } };"
      },
      "id": "build-report",
      "name": "Construire le rapport",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 670]
    },
