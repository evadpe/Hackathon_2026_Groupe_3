{
  "name": "StepAhead - Pipeline Conformite Documentaire",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "document-uploaded",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Declencheur upload documents",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 300],
      "webhookId": "document-uploaded"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://backend:8000/documents/pending",
        "options": {}
      },
      "id": "get-pending",
      "name": "Recuperer docs en attente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-empty",
              "leftValue": "={{ $json.length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-has-docs",
      "name": "Des documents a traiter ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "=",
        "options": {}
      },
      "id": "split-docs",
      "name": "Traiter chaque document",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [900, 200]
    },
    {
      "parameters": {
        "jsCode": "// Analyse les anomalies du document et détermine son niveau de risque\nconst doc = $input.item.json;\nconst anomalies = doc.anomalies || [];\n\nconst nbErreurs = anomalies.filter(a => a.severity === 'error').length;\nconst nbWarnings = anomalies.filter(a => a.severity === 'warning').length;\n\nlet niveau;\nif (nbErreurs > 0) {\n  niveau = 'CRITIQUE';\n} else if (nbWarnings > 0) {\n  niveau = 'A_VERIFIER';\n} else {\n  niveau = 'CONFORME';\n}\n\nreturn {\n  json: {\n    ...doc,\n    _analyse: {\n      niveau,\n      nbErreurs,\n      nbWarnings,\n      resumeAnomalies: anomalies.map(a => `[${a.severity?.toUpperCase()}] ${a.field}: ${a.message}`).join('\\n')\n    }\n  }\n};"
      },
      "id": "analyse-risk",
      "name": "Analyser le niveau de risque",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-critique",
              "leftValue": "={{ $json._analyse.niveau }}",
              "rightValue": "CRITIQUE",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "is-critique",
      "name": "Erreurs critiques ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1340, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-warning",
              "leftValue": "={{ $json._analyse.niveau }}",
              "rightValue": "A_VERIFIER",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "is-warning",
      "name": "Warnings seulement ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1560, 340]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "=http://backend:8000/documents/{{ $json.id }}/validate",
        "sendBody": true,
