            {
              "name": "extractedData",
              "value": "={{ $json.extractedData }}"
            }
          ]
        },
        "options": {}
      },
      "id": "auto-validate",
      "name": "Auto-valider vers Zone Gold",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1780, 480]
    },
    {
      "parameters": {},
